################################################################################
# OS / editor cruft
################################################################################
.DS_Store

################################################################################
# Large binary & data files (matched by extension, any depth)
################################################################################
# HDF5 family
*.h5
*.h5ad
*.hdf5
# Tabular / arrays
*.parquet
*.npy
# Imaging & misc binaries
*.tif
*.bin
*.vzg2
# Rendered reports & archives
*.html
*.zip
*.tar.gz

################################################################################
# Python
################################################################################
__pycache__/
*.pkl
*.pickle

################################################################################
# ML / segmentation models
################################################################################
# "models" dir at any depth
models/
# Cellpose-SAM model dirs (Vpt-segmentation, resegment_ROI_workflow)
cpsam/
*.model

################################################################################
# Build / temp output dirs
################################################################################
# Catch-all: any dir ending in "temp" (covers vzg_build_temp at any depth)
**/*temp/
# Explicit: name ends in "_v2", not caught by *temp above
**/vzg_build_temp_v2/
/.quarto/
quadro_test_files/

################################################################################
# Analysis & pipeline outputs
################################################################################
**/analysis_outputs/
**/analysis_outputs_old/
data_check/
DEGs/
Vignettes/

################################################################################
# Raw acquisition datasets & image patches (project-specific)
################################################################################
202504111150_Sessa-p0-p7_VMSC10702/
202503071102_SESSA-p30-E165_VMSC10702/
data_p0-p7/image_patches/
data_p30-E165/image_patches/R1_patch_*.png
Segmentation/Vpt-segmentation/image_patches/old/

################################################################################
# Resegmentation ROI analysis outputs (project-specific)
################################################################################
Segmentation/resegment_ROI_workflow/p30-E165_R1_default_1_ZLevel_cpsam_roi_analysis
Segmentation/resegment_ROI_workflow/p30-E165_R1_default_1_ZLevel_cpsam_v2_compatible_roi_analysis

